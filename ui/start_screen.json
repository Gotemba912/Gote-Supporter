{
  "namespace": "start",

  "quit_icon": {
    "type": "image",
    "texture": "textures/ui/cancel",
    "layer": 3,
    "size": [ 13, 13 ]
  },

  "op_icon": {
    "type": "image",
    "texture": "textures/ui/achievements",
    "layer": 3,
    "size": [ 16, 16 ]
  },

  "mail_icon": {
    "type": "image",
    "texture": "textures/ui/invite_mail",
    "layer": 3,
    "size": [ 16, 16 ]
  },

  "info_icon": {
    "type": "image",
    "texture": "textures/ui/info_icon",
    "layer": 3,
    "size": [ 16, 16 ]
  },

  "friends_icon": {
    "type": "image",
    "texture": "textures/ui/friendsbutton/navbar-friends-icon",
    "layer": 3,
    "size": [ 16, 16 ]
  },

  "topleft_quit_button@common_buttons.light_content_button": {
    "$pressed_button_name": "button.menu_exit",
    "size": [ 25, 25 ],
    "$button_content": "start.quit_icon",
    "$button_tts_header": "accessibility.button.exit"
  },

  "topleft_achievement_button@common_buttons.light_content_button": {
    "$pressed_button_name": "button.menu_achievements",
    "size": [ 25, 25 ],
    "$button_content": "start.op_icon",
    "$button_tts_header": "gui.achievements"
  },
 
  "topleft_invite_realm_button@common_buttons.light_content_button": {
    "$pressed_button_name": "button.menu_invite_notification",
    "size": [ 25, 25 ],
    "$button_content": "start.mail_icon",
    "$button_tts_header": "realmsInvitationScreen.shareTitle"
  },

  "topleft_invite_realm_panel": {
    "type": "panel",
    "size": [ 25, 25 ],
    "controls": [
      {
        "button@start.topleft_invite_realm_button": {}
      },
      {
        "count@start.notification_button_text_panel": {
          "offset": [ -3.5, 3 ],
          "bindings": [
            {
              "binding_name": "#realms_notification_count"
            },
            {
              "binding_type": "view",
              "source_property_name": "(not (#realms_notification_count = '0'))",
              "target_property_name": "#visible"
            }
          ]
        }
      }
    ]
  },


  "topleft_friends_drawer@common_buttons.light_content_button": {
    "$pressed_button_name": "button.friends_drawer",
    "size": [ 25, 25 ],
    "$button_content": "start.friends_icon",
    "$button_tts_header": "selectWorld.tab.friends"
  },

  "topleft_packinfo_button@common_buttons.light_content_button": {
    "$pressed_button_name": "button.menu_buy_game",
    "size": [ 25, 25 ],
    "$button_content": "start.info_icon",
    "$button_tts_header": "manifestvalidation.title"
  },

  "topleft_inbox_button@common_buttons.light_content_button": {
    "$pressed_button_name": "button.menu_inbox",
    "size": [ 25, 25 ],
    "$button_content": "start.inbox_bell_animated_icon",
    "$button_tts_header": "menu.inbox"
  },

  "topleft_profile_button@common_buttons.light_content_button": {
    "$pressed_button_name": "button.menu_profile",
    "size": [ 25, 25 ],
    "$button_content": "start.gamerpic_icon",
    "$button_tts_header": "menu.profile"
  },

  "buttons_padding": {
    "type": "panel",
    "size": [ 0, 1 ]
  },
  "buttons_panel":{
    "type": "stack_panel",
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "orientation": "horizontal",
    "size": [ 60, "100%" ],
    "offset": [ 5, 5 ],
    "controls":[
      {
        "buttons1": {
          "type": "stack_panel",
          "size": [ 25, "100%" ],
          "controls": [
            {"quit_button@start.topleft_quit_button":{}},
            {"padding_1@start.buttons_padding":{}},
            {"achievement_button@start.topleft_achievement_button": {}},
            {"padding_2@start.buttons_padding": {}},
            {"pack_info_button@start.topleft_packinfo_button": {}}
          ]
        }
      },
      {
        "padding": {
          "type": "panel",
          "size": [ 1, 0 ]
        }
      },
      {
        "buttons2": {
          "type": "stack_panel",
          "size": [ 25, "100%" ],
          "controls": [
            {"inbox_button@start.topleft_inbox_button": {}},
            {"padding_1@start.buttons_padding":{}},
            {"invite_realm_panel@start.topleft_invite_realm_panel": {}},
            {"padding_2@start.buttons_padding": {}},
            {"friends_drawer@start.topleft_friends_drawer": {}}
          ]
        }
      }
    ]
  },

  "realms_pending_invite_panel": {
    "ignored": true
  },

  "friendsdrawer_button_panel": {
    "ignored": true
  },
  
  "lower_online_buttons_panel": {
    "type": "stack_panel",
    "orientation": "horizontal",  
    "variables": [
      {
        "requires": "$start_screen_gamertag",
        "$size": [ 0, 6 ],
        "$controls": []
      },
      {
        "requires": "(not $start_screen_gamertag)",
        "$size": [ "100%c", 32 ],
        "$controls": [
          {
            "profile_btn_padding": {
              "type": "panel",
              "size": [ 5, "100%" ],
              "bindings": [
                {
                  "binding_name": "#profile_button_a_visible",
                  "binding_name_override": "#visible"
                }
              ]
            }
          },
          {
            "profile_btn@start.column_frame": {
              "size": [ "100%c", 32 ],
              "controls": [
                { "profile_button@start.profile_button": {} }
              ],
              "bindings": [
                {
                  "binding_name": "#profile_button_a_visible",
                  "binding_name_override": "#visible"
                }
              ]
            }
          }
        ]
      }
    ],
    "size": "$size",
    "controls": "$controls"
  },

  "play_button": {
    "button_mappings": [
      {
        "ignored": "($play_default_tab = 'servers')",
        "from_button_id": "button.menu_secondary_select",
        "to_button_id": "button.menu_servers",
        "mapping_type": "pressed"
      },
      {
        "ignored": "($play_default_tab = 'servers')",
        "from_button_id": "button.menu_select",
        "to_button_id": "$play_button_target",
        "mapping_type": "pressed"
      },
      {
        "ignored": "($play_default_tab = 'servers')",
        "from_button_id": "button.menu_ok",
        "to_button_id": "$play_button_target",
        "mapping_type": "focused"
      },
      
      {
        "ignored": "(not ($play_default_tab = 'servers'))",
        "from_button_id": "button.menu_secondary_select",
        "to_button_id": "$play_button_target",
        "mapping_type": "pressed"
      },
      {
        "ignored": "(not ($play_default_tab = 'servers'))",
        "from_button_id": "button.menu_select",
        "to_button_id": "button.menu_servers",
        "mapping_type": "pressed"
      },
      {
        "ignored": "(not ($play_default_tab = 'servers'))",
        "from_button_id": "button.menu_ok",
        "to_button_id": "button.menu_servers",
        "mapping_type": "focused"
      }
    ]
  },

  "gamertag_panel": {
    "type": "image",
    "texture": "textures/ui/gamertag_back",
    "size": [ "100%c + 4px", 32 ],
    "controls": [
      {
        "gamertag_panel": {
          "type": "stack_panel",
          "orientation": "horizontal",
          "size": [ "100%c", 24 ],
          "anchor_from": "top_left",
          "anchor_to": "top_left",
          "controls": [
            {
              "spacer_0": {
                "type": "panel",
                "size": [ 4, 0 ]
              }
            },
            {
              "gamerpic_with_border": {
                "type": "panel",
                "size": [ 24, 24 ],
                "controls": [
                  {
                    "gamerpic@common.focus_border_white": {
                      "layer": 3,
                      "size": [ 24, 24 ],
                      "offset": [ 0, 4 ],
                      "controls": [
                        {
                          "gamerpic_rederer": {
                            "type": "panel",
                            "bindings": [
                              {
                                "binding_name": "#show_gamerpic",
                                "binding_name_override": "#visible"
                              }
                            ],
                            "controls": [
                              {
                                "default": {
                                  "type": "custom",
                                  "renderer": "profile_image_renderer",
                                  "size": [ 22, 22 ],
                                  "layer": 2,
                                  "bindings": [
                                    {
                                      "binding_name": "#profile_image_options"
                                    },
                                    {
                                      "binding_type": "view",
                                      "source_property_name": "((#profile_image_options - '{\"type\":1') = #profile_image_options)",
                                      "target_property_name": "#visible"
                                    }
                                  ]
                                }
                              },
                              {
                                "force_xbox_icon": {
                                  "type": "custom",
                                  "renderer": "profile_image_renderer",
                                  "size": [ 22, 22 ],
                                  "layer": 2,
                                  "bindings": [
                                    {
                                      "binding_name": "#profile_image_options",
                                      "binding_name_override": "#rawjson"
                                    },
                                    {
                                      "binding_type": "view",
                                      "source_property_name": "('{\"type\":5' + (#rawjson - '{\"type\":1'))",
                                      "target_property_name": "#profile_image_options"
                                    },
                                    {
                                      "binding_type": "view",
                                      "source_property_name": "(not ((#rawjson - '{\"type\":1') = #rawjson))",
                                      "target_property_name": "#visible"
                                    }
                                  ]
                                }
                              }
                            ]
                          }
                        },
                        {
                          "gamerpic_default": {
                            "type": "image",
                            "texture": "textures/ui/gamerpic",
                            "size": [ 22, 22 ],
                            "layer": 2,
                            "bindings": [
                              {
                                "binding_name": "(not #show_gamerpic)",
                                "binding_name_override": "#visible"
                              }
                            ]
                          }
                        }
                      ]
                    }
                  }
                ]
              }
            },
            {
              "spacer_2": {
                "type": "panel",
                "size": [ 5, 0 ]
              }
            },
            {
              "label_panel": {
                "type": "panel",
                "size": [ "100%c", 24 ],
                "controls": [
                  {
                    "gamertag_label": {
                      "type": "label",
                      "color": "$main_header_text_color",
                      "text": "#gamertag_label",
                      "size": [ "default", 10 ],
                      "offset": [ 0, 4 ],
                      "shadow": true,
                      "bindings": [
                        {
                          "binding_name": "#gamertag_label"
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },

  "upper_online_buttons_panel": {
    "ignored": "(not $start_screen_gamertag)",
    "bindings": [],
    "modifications": [
      {
        "array_name": "controls",
        "operation": "insert_back",
        "value": [
          {
            "gamertag_panel": {
              "type": "panel",
              "size": [ "100%c", 32 ],
              "ignored": "$education_edition",
              "bindings": [
                {
                  "binding_name": "#profile_button_a_visible",
                  "binding_name_override": "#visible"
                }
              ],
              "controls": [
                {
                  "profile_button@common.button": {
                    "type": "button",
                    "size": [ "100%c", 32 ],
                    "offset": [ 3, 0 ],
                    "$pressed_button_name": "button.menu_profile",
                    "$button_tts_header": "menu.profile",
                    "controls": [
                      {
                        "default@start.gamertag_panel": {}
                      },
                      {
                        "hover@start.gamertag_panel": {
                          "texture": "textures/ui/gamertag_hover"
                        }
                      },
                      {
                        "pressed@start.gamertag_panel": {
                          "texture": "textures/ui/gamertag_hover"
                        }
                      }
                    ]
                  }
                }
              ]
            }
          }
        ]
      }
    ]
  },


  "label_background": {
    "type": "image",
    "texture": "textures/ui/White",
    "anchor_from": "top_right",
    "anchor_to": "top_right",
    "offset": [ 3, -1 ],
    "alpha": 0.6,
    "color": [ 0, 0, 0 ],
    "size": [ "100% + 4px", "100% + 2px" ],
    "layer": -5
  },

  "copyright_gote": {
    "type": "panel",
    "anchor_from": "bottom_middle",
    "anchor_to": "bottom_middle",
    "size": [ "100%", 10 ],
    "controls": [
      {
        "gote-supporter_version": {
          "type": "label",
          "color": "$main_header_text_color",
          "anchor_from": "top_left",
          "anchor_to": "top_left",
          "size": [ "default", 10 ],
          "offset": [ 0, -12 ],
          "text": "Gote-Supporter by ©Yuka0813",
          "layer": 1,
          "controls": [
            {
              "label_background@start.label_background": {}
            }
          ]
        }
      },
      {
        "minecraft_version": {
          "type": "label",
          "color": "$main_header_text_color",
          "anchor_from": "top_left",
          "anchor_to": "top_left",
          "size": [ "default", 10 ],
          "text": "Minecraft by %menu.copyright",
          "layer": 1,
          "controls": [
            {
              "label_background@start.label_background": {}
            }
          ]
        }
      }
    ]
  },

  "version_gote": {
    "type": "panel",
    "anchor_from": "bottom_middle",
    "anchor_to": "bottom_middle",
    "size": [ "100%-2px", 10 ],
    "controls": [
      {
        "gote-supporter_version": {
          "type": "label",
          "color": "$main_header_text_color",
          "anchor_from": "top_right",
          "anchor_to": "top_right",
          "size": [ "default", 10 ],
          "offset": [ 0, -12 ],
          "text": "('Gote-Supporter v' + $gote_ver)",
          "layer": 1,
          "controls": [
            {
              "label_background@start.label_background": {}
            }
          ]
        }
      },
      {
        "minecraft_version": {
          "type": "label",
          "color": "$main_header_text_color",
          "anchor_from": "top_right",
          "anchor_to": "top_right",
          "size": [ "default", 10 ],
          "text": "#text",
          "layer": 1,
          "property_bag": {
            "#mc_name": "Minecraft",
            "#mc_name_display": "Minecraft"
          },
          "bindings": [
            {
              "binding_name": "#version"
            },
            {
              "binding_name": "#development_version"
            },
            {
              "ignored": "(not $pre_release)",
              "binding_type": "view",
              "source_property_name": "(#mc_name + ' Preview')",
              "target_property_name": "#mc_name_display"
            },
            {
              "ignored": "$show_build_number",
              "binding_type": "view",
              "source_property_name": "(#mc_name_display + ' ' + #version)",
              "target_property_name": "#text"
            },
            {
              "ignored": "(not $show_build_number)",
              "binding_type": "view",
              "source_property_name": "(#mc_name_display + ' ' + #version + ' (' + #development_version + ')')",
              "target_property_name": "#text"
            }
          ],
          "controls": [
            {
              "label_background@start.label_background": {}
            }
          ]
        }
      }
    ]
  },

  "text_panel": {
    "ignored": true
  },

  "text_panel_custom": {
    "type": "panel",
    "size": [ "100%-2px", 10 ],
    "offset": [ 0, -1 ],
    "anchor_from": "bottom_middle",
    "anchor_to": "bottom_middle",
    "controls": [
      {
        "copyright_vanilla@start.copyright": {
          "ignored": "$show_gote_version"
        }
      },
      {
        "copyright_gote@start.copyright_gote": {
          "ignored": "(not $show_gote_version)"
        }
      },
      {
        "version_vanilla@start.version": {
          "ignored": "$show_gote_version"
        }
      },
      {
        "version_gote@start.version_gote": {
          "ignored": "(not $show_gote_version)"
        }
      }
    ]
  },

  "start_screen_content": {
    "modifications": [
      {
        "array_name": "controls",
        "operation": "insert_back",
        "value": [
          {
            "buttons_panel@start.buttons_panel": {}
          },
          {
            "text_panel_custom@start.text_panel_custom": {}
          }
        ]
      }
    ]
  }
}