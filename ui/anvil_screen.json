{
  "namespace": "anvil",

  "arrow_right_white": {
    "type": "image",
    "size": [ 4, 7 ],
    "texture": "textures/ui/arrow_right_white",
    "color": "$text_color",
    "layer": 2
  },

  "text_edit_panel": {
    "type": "panel",
    "anchor_from": "bottom_left",
    "anchor_to": "bottom_left",
    "size": [ "100%", "70%" ],
    "offset": [0, 2],
    "controls": [
      {
        "text_edit_box_stack": {
          "type": "stack_panel",
          "orientation": "horizontal",
          "anchor_from": "top_left",
          "anchor_to": "top_left",
          "size": [ "100%", 18 ],
          "controls": [
            {
              "text_edit_control@anvil.text_edit_control": {
                "size": [ "fill", "100%" ]
              }
            },
            {
              "padding": {
                "type": "panel",
                "size": [ 1, 0 ]
              }
            },
            {
              "open_editor@gtb.swtich_toggle_c": {
                "size": [ 18, 18 ],
                "$toggle_name": "open_editor",
                "$toggle_view_binding_name": "open_editor_toggle",
                "$toggle_group_forced_index": 100,
                "$button_content": "anvil.arrow_right_white",
                "$pressed_button_name": "button.dummy",
                "bindings": [
                  {
                    "binding_name": "#text_box_enabled",
                    "binding_name_override": "#enabled"
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },

  "item_name_editor@common_dialogs.main_panel_no_buttons": {
    "layer": 100,
    "size": [ "80%", "80%" ],
    "$text_name": "%tile.anvil.name - %chalkboardScreen.header",
    "$show_close_button": false,
    "$child_control": "anvil.item_name_editor_box",
    "bindings": [
      {
        "binding_type": "view",
        "source_control_name": "open_editor_toggle",
        "source_property_name": "#toggle_state",
        "target_property_name": "#visible"
      }
    ]
  },

  "item_name_editor_box": {
    "type": "panel",
    "size": [ "100%", "100%" ],
    "controls": [
      {
        "editor_esc_close@gtb.close_swtich_toggle_esc": {
          "layer": 101,
          "size": [ 0, 0 ],
          "$toggle_name": "open_editor",
          "$toggle_default_state": true,
          "$toggle_group_forced_index": 0
        }
      },
      {
        "text_edit_control@common.multiline_text_edit_box": {
          "layer": 103,
          "size": [ "100%", "100%" ],
          "anchor_from": "top_left",
          "anchor_to": "top_left",
          "property_bag": {
            "#property_field": "#item_name"
          },
          "max_length": 32767,
          "$text_edit_binding_name": "#text_box_item_name"
        }
      },
      {
        "editor_close_button@gtb.close_button": {
          "layer": 102,
          "$toggle_name": "open_editor"
        }
      }
    ]
  },

  "anvil_panel/root_panel": {
    "bindings": [
      {
        "binding_type": "view",
        "source_control_name": "open_editor_toggle",
        "source_property_name": "(not #toggle_state)",
        "target_property_name": "#visible"
      }
    ]
  },

  "anvil_panel": {
    "modifications": [
      {
        "array_name": "controls",
        "operation": "insert_front",
        "value": [
          {
            "status_bar@crafting.status_bar": {}
          },
          {
            "player_renderer@chest.player_renderer": {}
          },
          {
            "item_name_editor@anvil.item_name_editor": {}
          }
        ]
      }
    ]
  }
}