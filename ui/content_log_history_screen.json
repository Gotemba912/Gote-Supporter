  "filtered_log@content_log_history.content_log_message": {
    "$filter|default": "[Localization]",
    "$visible_toggle|default": "no_filter",
    "bindings": [
      {
        "binding_type": "collection",
        "binding_name": "#content_log_text",
        "binding_name_override": "#text",
        "binding_collection_name": "content_log_message"
      },
      {
        "binding_type": "view",
        "source_control_name": "$visible_toggle",
        "source_property_name": "#toggle_state",
        "target_property_name": "#ts"
      },
      {
        "binding_type": "view",
        "source_property_name": "(#ts and (not ((#text - $filter) = #text)))",
        "target_property_name": "#visible"
      }
    ]
  },

