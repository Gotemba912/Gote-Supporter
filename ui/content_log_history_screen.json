{
  "namespace": "content_log_history",
  
  "filter_icon": {
    "layer": 1,
    "type": "image",
    "texture": "textures/ui/store_filter_icon",
    "size": [ 17, 17 ]
  },
 
  "main_panel": {
    "type": "panel",
    "size": [ "100%", "100%" ],
    "controls": [
      {
        "main_stack_panel@content_log_history.main_stack_panel": {}
      },
      {
        "filter_toggles@common.scrolling_panel": {
          "size": [ 100, "100% - 27px" ],
          "offset": [ 0, 27 ],
          "anchor_from": "top_right",
          "anchor_to": "top_right",
          "layer": 334,
          "$scrolling_content": "content_log_history.filter_toggles",
          "$show_background": false,
          "bindings": [
            {
              "binding_type": "view",
              "source_control_name": "filter_toggle",
              "source_property_name": "#toggle_state",
              "target_property_name": "#visible"
            }
          ]
        }
      }
    ]
  },
  
  "main_stack_panel": {
    "type": "stack_panel",
    "orientation": "vertical",
    "size": [ "100%", "100%" ],
    "controls": [
      {
        "bottom_buttons": {
          "type": "stack_panel",
          "orientation": "horizontal",
          "size": [ "100%", 27 ],
          "controls": [
            {
              "clear_button@common_buttons.light_content_button": {
                "size": [ 27, 27 ],
                "$button_content": "content_log_history.clear_icon",
                "$pressed_button_name": "button.clear"
              }
            },
            {
              "copy_button@common_buttons.light_content_button": {
                "size": [ 27, 27 ],
                "$button_content": "content_log_history.clipboard_icon",
                "$pressed_button_name": "button.copy_to_clipboard"
              }
            },
            {
              "spacer": {
                "type": "panel",
                "size": [ "fill", 27 ],
                "controls": [
                  {
                    "filter_info@content_log_history.filter_info": {}
                  }
                ]
              }
            },
            {
              "filter_button@common_toggles.light_content_toggle": {
                "size": [ 27, 27 ],
                "$button_content": "content_log_history.filter_icon",
                "$toggle_name": "filter_toggle",
                "$toggle_view_binding_name": "filter_toggle"
              }
            }
          ]
        }
      },
      {
        "messages_scrolling_panel@content_log_history.messages_scrolling_panel": {
          "size": [ "100%", "fill" ]
        }
      }
    ]
  },
    
  "filter_toggle_item@common_toggles.dark_content_toggle": {
    "size": [ "100%", 20 ],
    "$radio_toggle_group": true,
    "$button_text": "フィルターなし",
    "$button_content": "content_log_history.filter_toggle_content",
    "$toggle_name": "filter_select_toggle",
    "$toggle_view_binding_name": "no_filter"
  },

  "filter_toggle_content": {
    "type": "stack_panel",
    "orientation": "horizontal",
    "size": [ "100% - 4px", 10 ],
    "layer": 1,
    "controls": [
      {
        "checkbox_check": {
          "type": "panel",
          "size": [ 10, 10 ],
          "controls": [
            {
              "checkbox_check": {
                "type": "image",
                "texture": "textures/ui/radio_on",
                "visible": "($toggle_checked or $toggle_checked_hover)"
              }
            }
          ]
        }
      },
      {
        "padding": {
          "type": "panel",
          "size": [ 2, 0 ]
        }
      },
      {
        "label": {
          "type": "label",
          "size": [ "fill", 10 ],
          "text": "$button_text"
        }
      }
    ]
  },

